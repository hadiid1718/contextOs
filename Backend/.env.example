NODE_ENV=development
PORT=4001
MONGO_URI=mongodb://localhost:27017/contextos-auth
APP_ORIGIN=http://localhost:3000
API_BASE_URL=http://localhost:4001

JWT_ACCESS_SECRET=replace_with_access_secret
JWT_REFRESH_SECRET=replace_with_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

ACCESS_COOKIE_NAME=accessToken
REFRESH_COOKIE_NAME=refreshToken
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=replace_with_mail_password
MAIL_FROM="ContextOS <noreply@contextos.io>"

GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4001/api/v1/auth/oauth/google/callback

GITHUB_CLIENT_ID=replace_with_github_client_id
GITHUB_CLIENT_SECRET=replace_with_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:4001/api/v1/auth/oauth/github/callback

OAUTH_SUCCESS_REDIRECT=http://localhost:3000/auth/success
OAUTH_FAILURE_REDIRECT=http://localhost:3000/auth/failure
